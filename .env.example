# HeroSMS-compatible SMS provider API key; required for buying/monitoring phone activations.
HEROSMS_API_KEY=your-herosms-api-key
# Maximum price per phone activation; lower values reduce spend but may reduce availability.
GPTFREE_HEROSMS_MAX_PRICE=0.03

# Safety gate for real registration; set to 1 only when SMS, browser, proxy, and panel are configured.
GPTFREE_ALLOW_REAL_REGISTRATION=0

# Import backend mode: cpa for CPA OAuth helper flow, sub2api for Sub2API-compatible panel import.
GPTFREE_PANEL_MODE=cpa

# CPA-compatible management API base URL used by the helper for OAuth URL/callback/status.
GPTFREE_CPA_URL=http://127.0.0.1:8317
# CPA management key/password used in X-Management-Key and Authorization headers.
GPTFREE_CPA_MANAGEMENT_KEY=your-cpa-management-key
# Optional file from which the helper can read MANAGEMENT_PASSWORD when env key is absent.
GPTFREE_CPA_ENV_FILE=~/.gptfree/cpa.env
# Directory where the helper stores generated OAuth state JSON.
GPTFREE_CPA_STATE_DIR=~/.gptfree/state/gptfree-cpa-existing-account
# Optional verification script run when helper --verify is used.
GPTFREE_CPA_OAUTH_VERIFY_SCRIPT=~/.gptfree/scripts/cpa-oauth-verify.py

# Sub2API-compatible panel base URL.
GPTFREE_SUB2API_URL=http://127.0.0.1:8080
# Sub2API administrator login email.
GPTFREE_SUB2API_EMAIL=admin@example.com
# Sub2API administrator login password.
GPTFREE_SUB2API_PASS=your-sub2api-password

# Cloud Mail API base URL used by cloud_mail_local.py.
CLOUD_MAIL_BASE_URL=https://mail.example.com
# Cloud Mail inbox domain used when creating temporary addresses.
CLOUD_MAIL_DOMAIN=example.com
# Cloud Mail administrator email used to obtain an API token.
CLOUD_MAIL_ADMIN_EMAIL=admin@example.com
# Cloud Mail administrator password used to obtain an API token.
CLOUD_MAIL_ADMIN_PASSWORD=your-cloud-mail-password
# Domain used by batch_register_v2.py when reconstructing helper-created CPA email addresses.
GPTFREE_EMAIL_DOMAIN=example.com

# Optional legacy Cloudflare Temp Email-compatible API base URL.
GPTFREE_CF_TEMP_EMAIL_URL=https://example.com
# Optional legacy Cloudflare Temp Email authorization token/header value.
GPTFREE_CF_TEMP_EMAIL_AUTH=

# Chrome DevTools Protocol port used by main script/helper.
GPTFREE_CDP_PORT=9336
# Chrome profile directory for registration browser state.
GPTFREE_CHROME_PROFILE=/tmp/chrome-reg-current
# Optional browser proxy server, e.g. http://127.0.0.1:7890; leave empty to disable custom proxy.
GPTFREE_PROXY_SERVER=

# Directory for auto_batch_monitor.py logs.
GPTFREE_AUTO_BATCH_LOG_DIR=~/.gptfree/auto_batch_logs
# State file used by auto_batch_monitor.py for resumable monitoring.
GPTFREE_AUTO_BATCH_STATE_FILE=~/.gptfree/auto_batch_state.json
