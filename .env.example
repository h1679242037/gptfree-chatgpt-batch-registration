# HeroSMS-compatible SMS provider
HEROSMS_API_KEY=your-herosms-api-key
GPTFREE_HEROSMS_MAX_PRICE=0.03

# Runtime gate for real registration
GPTFREE_ALLOW_REAL_REGISTRATION=0

# Panel mode: cpa or sub2api
GPTFREE_PANEL_MODE=cpa

# CPA-compatible management API
GPTFREE_CPA_URL=http://127.0.0.1:8317
GPTFREE_CPA_MANAGEMENT_KEY=your-cpa-management-key
GPTFREE_CPA_ENV_FILE=~/.gptfree/cpa.env
GPTFREE_CPA_STATE_DIR=~/.gptfree/state/gptfree-cpa-existing-account
GPTFREE_CPA_OAUTH_VERIFY_SCRIPT=~/.gptfree/scripts/cpa-oauth-verify.py

# Sub2API-compatible panel
GPTFREE_SUB2API_URL=http://127.0.0.1:8080
GPTFREE_SUB2API_EMAIL=admin@example.com
GPTFREE_SUB2API_PASS=your-sub2api-password

# Cloud Mail-compatible temporary email API
GPTFREE_CLOUD_MAIL_URL=https://mail.example.com
GPTFREE_CLOUD_MAIL_EMAIL=admin@example.com
GPTFREE_CLOUD_MAIL_PASS=your-cloud-mail-password
GPTFREE_EMAIL_DOMAIN=example.com

# Cloudflare Temp Email-compatible API (optional legacy mode)
GPTFREE_CF_TEMP_EMAIL_URL=https://example.com
GPTFREE_CF_TEMP_EMAIL_AUTH=

# Browser/CDP
GPTFREE_CDP_PORT=9336
GPTFREE_CHROME_PROFILE=/tmp/chrome-reg-current
GPTFREE_PROXY_SERVER=

# Auto batch monitor paths
GPTFREE_AUTO_BATCH_LOG_DIR=~/.gptfree/auto_batch_logs
GPTFREE_AUTO_BATCH_STATE_FILE=~/.gptfree/auto_batch_state.json
